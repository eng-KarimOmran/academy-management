generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model ProofOfPaymentImage {
  id                 String              @id @default(cuid())
  imageUrl           String
  publicId           String
  ledgerTransactions LedgerTransaction[]
}

model AcademyPhone {
  id        String  @id @default(cuid())
  phone     String  @unique
  academy   Academy @relation(fields: [academyId], references: [id])
  academyId String
}

model ClientPhone {
  id        String  @id @default(cuid())
  phone     String
  academy   Academy @relation(fields: [academyId], references: [id])
  academyId String
  client    Client  @relation(fields: [clientId], references: [id])
  clientId  String

  @@unique([phone, academyId])
}

model FinancialAccount {
  id             String        @id @default(cuid())
  jobProfile     JobProfile?   @relation(fields: [jobProfileId], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  academy        Academy?      @relation(fields: [academyId], references: [id])
  jobProfileId   String?       @unique
  subscriptionId String?       @unique
  academyId      String?       @unique

  sentTransactions     LedgerTransaction[] @relation("Sender")
  receivedTransactions LedgerTransaction[] @relation("Receiver")
}

model Address {
  id        String  @id @default(cuid())
  address   String
  academy   Academy @relation(fields: [academyId], references: [id])
  academyId String
}

model PaymentLink {
  id             String  @id @default(cuid())
  url            String
  phone          String?
  walletProvider String
  academy        Academy @relation(fields: [academyId], references: [id])
  academyId      String
}

enum Platform {
  FACEBOOK
  TIKTOK
  INSTAGRAM
  TWITTER
  YOUTUBE
  LINKEDIN
  SNAPCHAT
  WHATSAPP
}

model SocialMedia {
  id        String   @id @default(cuid())
  platform  Platform
  url       String
  academy   Academy  @relation(fields: [academyId], references: [id])
  academyId String
}

model Academy {
  id                 String              @id @default(cuid())
  name               String              @unique
  createdAt          DateTime            @default(now())
  addresses          Address[]
  paymentLinks       PaymentLink[]
  socialMedia        SocialMedia[]
  courses            Course[]
  clients            Client[]
  subscriptions      Subscription[]
  lessons            Lesson[]
  owners             User[]              @relation("AcademyOwners")
  jobProfiles        JobProfile[]
  cars               Car[]
  areas              Area[]
  ledgerTransactions LedgerTransaction[]
  academyPhones      AcademyPhone[]
  clientPhones       ClientPhone[]
  financialAccount   FinancialAccount?
  payrolls           Payroll[]
}

model BlacklistedToken {
  jti       String   @unique
  expiresAt DateTime

  @@index([expiresAt])
}

model Client {
  id            String         @id @default(cuid())
  name          String
  phones        ClientPhone[]
  academyId     String
  academy       Academy        @relation(fields: [academyId], references: [id], onDelete: Restrict)
  source        ClientSource   @default(OFFICE)
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
}

enum ClientSource {
  PLATFORM
  OFFICE
}

enum SubscriptionStatus {
  PENDING_DEPOSIT
  PENDING_FIRST_SESSION
  ACTIVE_LIMITED
  ACTIVE
  CANCELED
  COMPLETED
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

model Course {
  id                        String            @id @default(cuid())
  name                      String
  description               String
  isActive                  Boolean           @default(true)
  priceOriginal             Float
  priceDiscounted           Float
  requiredInitialDeposit    Float
  totalSessions             Int
  sessionsBeforeFullPayment Int
  sessionDurationMinutes    Int
  featuredReason            String?
  academyId                 String
  academy                   Academy           @relation(fields: [academyId], references: [id], onDelete: Restrict)
  features                  TrainingDetails[]
  subscriptions             Subscription[]
  createdAt                 DateTime          @default(now())

  @@unique([academyId, name])
}

model Subscription {
  id                 String             @id @default(cuid())
  subscriptionStatus SubscriptionStatus @default(PENDING_DEPOSIT)

  priceAtBooking             Float
  totalSessions              Int
  sessionDurationMinutes     Int
  requiredInitialDeposit     Float
  sessionsBeforeFullPayment  Int
  trainingTypeAtRegistration Transmission

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Restrict)

  academyId String
  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)

  createdById String?
  createdBy   JobProfile? @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  lessons            Lesson[]
  ledgerTransactions LedgerTransaction[]
  financialAccount   FinancialAccount?

  createdAt DateTime @default(now())
  payroll   Payroll? @relation(fields: [payrollId], references: [id])
  payrollId String?

  @@index([clientId])
  @@index([academyId])
}

enum JobProfileType {
  TRAINER
  SECRETARY
  MANAGER
}

model JobProfile {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  academyId String
  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)

  jobProfileType JobProfileType

  isActive Boolean @default(true)

  baseSalary  Float       @default(0)
  lessonPrice Float       @default(0)
  supportType SupportType

  targetCount Int   @default(0)
  bonusAmount Float @default(0)

  createdAt        DateTime          @default(now())
  financialAccount FinancialAccount?
  subscriptions    Subscription[]    @relation("CreatedBy")
  lessons          Lesson[]
  payrolls         Payroll[]

  @@unique([academyId, userId])
}

model User {
  id                String   @id @default(cuid())
  name              String
  phone             String   @unique
  password          String
  isActive          Boolean  @default(true)
  email             String?  @unique
  logoutAt          DateTime @default(now())
  isPasswordChanged Boolean  @default(false)
  isAdmin           Boolean  @default(false)

  jobProfile JobProfile[]
  academies  Academy[]    @relation("AcademyOwners")

  createdAt DateTime @default(now())
}

enum SupportType {
  MANUAL
  AUTOMATIC
  BOTH
}

model TrainingDetails {
  id       String @id @default(cuid())
  feature  String
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Car {
  id              String       @id @default(cuid())
  modelName       String
  plateNumber     String
  gearType        Transmission
  carSessionPrice Float
  isActive        Boolean      @default(true)
  lessons         Lesson[]
  academy         Academy      @relation(fields: [academyId], references: [id])
  academyId       String
  createdAt       DateTime     @default(now())

  @@unique([plateNumber, academyId])
}

model Area {
  id          String      @id @default(cuid())
  name        String
  supportType SupportType
  isActive    Boolean     @default(true)
  lessons     Lesson[]
  academy     Academy     @relation(fields: [academyId], references: [id])
  academyId   String
  createdAt   DateTime    @default(now())

  @@unique([name, academyId])
}

model Lesson {
  id                 String       @id @default(cuid())
  startTime          DateTime
  endTime            DateTime
  lessonStatus       LessonStatus @default(SCHEDULED)
  transmission       Transmission
  expectedAmount     Float?
  carSessionPrice    Float
  captainLessonPrice Float
  academyId          String

  academy        Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)
  subscriptionId String

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  car   Car    @relation(fields: [carId], references: [id], onDelete: Restrict)
  carId String

  ledgerTransaction   LedgerTransaction? @relation(fields: [ledgerTransactionId], references: [id], onDelete: Restrict)
  ledgerTransactionId String?

  area   Area   @relation(fields: [areaId], references: [id], onDelete: Restrict)
  areaId String

  jobProfile   JobProfile @relation(fields: [jobProfileId], references: [id])
  jobProfileId String

  createdAt DateTime @default(now())

  payroll   Payroll? @relation(fields: [payrollId], references: [id])
  payrollId String?
}

enum LessonStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  CANCELED_CHARGED
}

model LedgerTransaction {
  id String @id @default(cuid())

  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)
  academyId String

  transactionType TransactionType

  paymentMethod PaymentMethod

  senderId String
  sender   FinancialAccount @relation("Sender", fields: [senderId], references: [id], onDelete: Restrict)

  receiverId String
  receiver   FinancialAccount @relation("Receiver", fields: [receiverId], references: [id], onDelete: Restrict)

  amount Decimal @db.Decimal(12, 2)

  proofOfPaymentImageId String?
  proofOfPaymentImage   ProofOfPaymentImage? @relation(fields: [proofOfPaymentImageId], references: [id], onDelete: SetNull)

  createdAt      DateTime      @default(now())
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  subscriptionId String?
  lessons        Lesson[]
  payroll        Payroll?

  @@index([senderId])
  @@index([receiverId])
}

enum PaymentMethod {
  MONETARY
  ELECTRONIC
}

enum TransactionType {
  CUSTOMER_PAYMENT
  CUSTOMER_REFUND
  EMPLOYEE_TRANSFER_TO_EMPLOYEE
  EMPLOYEE_TRANSFER_TO_ACADEMY
  ACADEMY_TRANSFER_TO_EMPLOYEE
}

model Payroll {
  id String @id @default(cuid())

  jobProfileId String
  jobProfile   JobProfile @relation(fields: [jobProfileId], references: [id], onDelete: Restrict)

  academyId String
  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)

  periodFrom DateTime
  periodTo   DateTime

  baseSalary              Float
  totalLessonsCount       Int
  totalLessonsAmount      Float
  totalSubscriptionsCount Int
  targetCount             Int
  bonusAmount             Float
  totalDeductions         Float
  netAmount               Float

  lessons       Lesson[]
  subscriptions Subscription[]

  ledgerTransactionId String            @unique
  ledgerTransaction   LedgerTransaction @relation(fields: [ledgerTransactionId], references: [id])

  createdAt DateTime @default(now())
}
